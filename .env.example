# XHS Blogger Analyzer — 环境变量配置
# 复制为 .env 后修改

# LLM 配置（AI Agent 爆款拆解/账号诊断/内容仿写）
# 支持厂商: openai, deepseek, kimi, qwen, glm, claude, custom
LLM_PROVIDER=openai
LLM_API_KEY=
MAX_ACTIVE_TASKS_PER_USER=1
MAX_NOTES_PER_TASK=100
MAX_COMPETITOR_COUNT=5
# LLM_API_URL=  # 可选，覆盖默认 API 地址
# LLM_MODEL=     # 可选，覆盖默认模型

# JWT Secret（生产环境请修改）
SECRET_KEY=change-me-in-production
